{
    "name": "secure-messenger-desktop",
    "version": "1.0.0",
    "main": "out/main/main.js",
    "scripts": {
        "dev": "node scripts/start-electron.js",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "test": "vitest",
        "postinstall": "electron-builder install-app-deps"
    },
    "dependencies": {
        "@emotion/react": "^11.11.1",
        "@emotion/styled": "^11.11.0",
        "@mui/icons-material": "^5.14.3",
        "@mui/material": "^5.14.3",
        "@reduxjs/toolkit": "^1.9.5",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-redux": "^8.1.1",
        "react-window": "^1.8.9",
        "sqlite3": "^5.1.7",
        "ws": "^8.13.0"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.4",
        "@types/react": "^18.2.15",
        "@types/react-dom": "^18.2.7",
        "@types/react-window": "^1.8.5",
        "@types/ws": "^8.5.5",
        "@vitejs/plugin-react": "^4.0.3",
        "electron": "^40.2.1",
        "electron-builder": "^24.6.3",
        "electron-vite": "^1.0.27",
        "jsdom": "^28.0.0",
        "typescript": "^5.1.6",
        "vite": "^4.4.4",
        "vitest": "^0.33.0"
    },
    "build": {
        "appId": "com.example.secure-messenger",
        "productName": "Secure Messenger",
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": "nsis"
        },
        "mac": {
            "target": "dmg"
        },
        "linux": {
            "target": "AppImage"
        }
    }
}